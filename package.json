{
  "name": "online-mall",
  "private": true,
  "workspaces": [
    "web",
    "worker"
  ],
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,magenta \"npm run dev -w web\" \"npm run dev -w worker\"",
    "build": "npm run build -w web && npm run build -w worker",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply online-mall-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply online-mall-db --remote"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "wrangler": "^4.14.0"
  }
}
